# Universal OS/editor ignores shared by every subproject in this monorepo.
# Stack-specific ignores (Java/Maven, Node, etc.) belong in each subproject's own .gitignore
# (see backend/.gitignore) — nested .gitignore files apply within their own subtree.
.idea/
*.iml
.vscode/
.DS_Store
Thumbs.db

# Git worktrees for isolated feature development (see backend/.claude/skills/using-git-worktrees)
.worktrees/
