# ---- Java / Maven ----
target/
*.class
*.jar
*.war
!.mvn/wrapper/maven-wrapper.jar
.mvn/timing.properties

# ---- Logs (logback rolling files, §6.10) ----
logs/
*.log
*.log.gz

# ---- Local / secret config (never commit) ----
.env
.env.*
application-local.yml
application-local.yaml
*.pem
*.key
*.p12
*.pfx
*.jks
infra/production/.state/
infra/production/backups/

# ---- Claude Code ----
# Personal, machine-specific overrides — commit settings.json, not this.
.claude/settings.local.json
# Auto-generated by Claude Code:
.claude/plugins/
.claude/projects/

# ---- IDE / OS ----
.idea/
*.iml
.vscode/
.DS_Store
Thumbs.db

# ---- GitNexus local index (graph DB + parse cache) ----
# The repository is indexed once from its root as TVU-Event-Ticket; there is no separate backend index.
# This entry only guards against a stray index created by running analyze from inside backend/.
.gitnexus/

# ---- Eclipse / VSCode-Java per-machine metadata ----
# org.eclipse.jdt.core.prefs is committed on purpose (it narrows the null analysis; see that file's header).
# The rest of .settings/ is IDE-generated and personal.
.settings/org.eclipse.core.resources.prefs
.settings/org.eclipse.m2e.core.prefs
