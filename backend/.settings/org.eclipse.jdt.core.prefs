eclipse.preferences.version=1
# Read by the VSCode Java extension (Eclipse JDT LS). Narrows the null analysis that
# .vscode/settings.json enables via java.compile.nullAnalysis.mode=automatic.
#
# Null analysis stays ON: it is what surfaced the getExpiresAt() short-circuit in CookieCsrfFilter.
# What is silenced is only the "unchecked conversion" family, which fires when a method reference is
# handed to a third-party functional interface that carries no null annotations -- AssertJ's
# extracting(Ticket::getId), Mockito's argument matchers, and Stream.toMap. Those produce
# "Null type safety: parameter 'this' provided via method descriptor ..." on 24 call sites in this
# repo, none of which is reachable as a real null: AssertJ never invokes the extractor on a null
# element. They are unfixable from our side short of wrapping every method reference in a lambda.
org.eclipse.jdt.core.compiler.problem.nullUncheckedConversion=ignore
org.eclipse.jdt.core.compiler.problem.nonnullParameterAnnotationDropped=ignore
