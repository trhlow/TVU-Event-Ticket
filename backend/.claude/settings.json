{
  "permissions": {
    "allow": [
      "Bash(docker info *)",
      "Bash(mvn -version *)",
      "Bash(command -v *)",
      "Bash(git merge-base *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-secrets.sh"
          }
        ]
      }
    ]
  }
}
