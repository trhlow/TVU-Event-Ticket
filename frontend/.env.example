# Base URL of the API Gateway (must include /api). Never point production at localhost.
VITE_API_BASE_URL=http://localhost:8080/api

# development | production. Defaults to Vite's own build mode when unset.
# When production, the app refuses to start if VITE_AUTH_PROVIDER=devstub (see src/lib/env.ts).
VITE_APP_ENV=development

# microsoft | devstub. Selects the STUDENT sign-in panel only. The admin panel is always the
# emailed-code flow and cannot be switched off here. devstub maps to the backend's dev-only,
# password-less identity stub and must never be used outside local development.
VITE_AUTH_PROVIDER=microsoft

# Must both stay false outside local development / demo recordings. When true, service layers may
# serve fixture data instead of real API responses. See backend/docs/BACKEND_SECURITY_REQUIREMENTS.md.
VITE_USE_DEMO_DATA=false
VITE_ENABLE_MOCK_FALLBACK=false

VITE_MICROSOFT_CLIENT_ID=
VITE_MICROSOFT_TENANT_ID=
VITE_MICROSOFT_REDIRECT_URI=http://localhost:5173
